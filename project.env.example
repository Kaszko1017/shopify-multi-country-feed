# Shopify (required)
SHOPIFY_TOKEN=your_shopify_admin_api_token
STORE_ID=your-store-name
SHOPIFY_API_VERSION=2024-07

# Google: required — only these countries (that exist in Shopify markets) get TSV feeds.
# Meta: optional by default — feeds follow all Shopify market countries unless you set:
# META_FILTER_TARGET_COUNTRIES=true
TARGET_COUNTRIES=US,CA,AE
# META_FILTER_TARGET_COUNTRIES=false

# Google target: optional feed ID prefix for Merchant Center (default: shopify_US_)
# FEED_ID_PREFIX=shopify_US_

# Google Drive (optional – uploads skipped if not set)
# Preferred: set target-specific folders.
GOOGLE_DRIVE_FOLDER_ID_GOOGLE=your_google_drive_google_target_folder_id
GOOGLE_DRIVE_FOLDER_ID_META=your_google_drive_meta_target_folder_id
# Backward-compatible shared fallback (used when target-specific vars are missing):
# GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json

# Performance
BULK_CHUNK_SIZE=1000
MAX_RETRIES=3
BASE_RETRY_DELAY=2.0
MAX_RETRY_DELAY=60.0
CSV_BUFFER_SIZE=65536

# Features
SMART_MAPPING_ENABLED=true
ENABLE_DATA_VALIDATION=true
MAX_INVENTORY_THRESHOLD=100000
